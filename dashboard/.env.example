# Auth0 OpenID Connect — required in ALL environments (local + Vercel)
# Get these from your Auth0 application settings
AUTH0_CLIENT_ID=<your-auth0-client-id>
AUTH0_CLIENT_SECRET=<your-auth0-client-secret>
AUTH0_ISSUER_BASE_URL=https://<your-auth0-domain>.eu.auth0.com
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH0_SESSION_SECRET=<random-32-byte-hex>

# Application base URL (used for /callback redirect)
# Local dev:
BASE_URL=http://localhost:3000
# Vercel production: set to your deployment URL in the Vercel dashboard
# BASE_URL=https://your-app.vercel.app
